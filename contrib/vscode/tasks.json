{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "zscan: build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "zscan: scan (this folder)",
      "type": "shell",
      "command": "node dist/cli.js scan-all --root ${workspaceFolder}",
      "dependsOn": ["zscan: build"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "zscan: serve HTTP",
      "type": "shell",
      "command": "node dist/cli.js serve --port 8787",
      "dependsOn": ["zscan: build"],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
